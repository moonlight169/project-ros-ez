#include <Arduino.h>
#include <SPI.h>
#include <Ethernet.h>

// --- ตั้งค่าพิน ---
const int eth_cs = 5;
const int eth_rst = 26;

// --- ตั้งค่า Network (วง 10.0.0.x ถูกต้องแล้วสำหรับต่อตรง PC) ---
byte mac[] = { 0xDE, 0xAD, 0xBE, 0xEF, 0xFE, 0x01 };
IPAddress ip(192, 168, 200, 177);
IPAddress dns(8, 8, 8, 8);
IPAddress gateway(192, 168, 200, 1);
IPAddress subnet(255, 255, 255, 0);

void setup() {
  Serial.begin(115200);
  while (!Serial); 

  // 1. จัดการพิน Reset (ย้ายไปเสียบที่ขา 26 ของ ESP32 แทนนะครับ)
  pinMode(eth_rst, OUTPUT);
  digitalWrite(eth_rst, LOW);
  delay(100);
  digitalWrite(eth_rst, HIGH);
  delay(500);

  // 2. ตั้งค่า SPI และ CS
  Ethernet.init(eth_cs);

  // 3. เริ่มต้นด้วย Static IP
  Serial.println("Starting Ethernet with Static IP...");
  Ethernet.begin(mac, ip, dns, gateway, subnet);

  // 4. ตรวจสอบสถานะ
  if (Ethernet.hardwareStatus() == EthernetNoHardware) {
    Serial.println("Error: W5500 was not found. Check wiring!");
  } else if (Ethernet.linkStatus() == LinkOFF) {
    Serial.println("Error: Ethernet cable is not connected.");
  } else {
    Serial.print("SUCCESS! My IP: ");
    Serial.println(Ethernet.localIP());
  }
}

void loop() {
}