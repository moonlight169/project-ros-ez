#include <SPI.h>
#include <Ethernet.h>

// --- ตั้งค่า Hardware ---
// W5500 มักใช้ขา CS (SS) ที่ขา 5 (สำหรับ ESP32) หรือตามที่คุณต่อไว้
const int W5500_CS = 5; 

// --- ตั้งค่า Network ---
byte mac[] = { 0xDE, 0xAD, 0xBE, 0xEF, 0xFE, 0xED }; // ใส่เลขมั่วๆ ได้แต่ห้ามซ้ำในวง
IPAddress ip(192, 168, 1, 50);       // IP ของ W5500 (เรากำหนดเอง)
IPAddress my_subnet(255, 255, 255, 0);

void setup() {
  Serial.begin(115200);
  
  // เริ่มต้นการทำงาน W5500
  Ethernet.init(W5500_CS); 
  
  Serial.println("Starting Ethernet (Static IP)...");
  Ethernet.begin(mac, ip); // บังคับใช้ Static IP ที่เราตั้งไว้
  
  // เช็คสถานะ Hardware
  if (Ethernet.hardwareStatus() == EthernetNoHardware) {
    Serial.println("W5500 not found! Check wiring.");
  } else if (Ethernet.linkStatus() == LinkOFF) {
    Serial.println("Ethernet cable is not connected.");
  }

  Serial.print("ESP32 W5500 IP: ");
  Serial.println(Ethernet.localIP());
}

void loop() {
  // ทำงานอย่างอื่น...
}