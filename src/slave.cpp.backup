#include <Arduino.h>
#include <HardwareSerial.h>

#define MY_WHEEL 1
#define PIN_ENABLE 4
#define RXTX_PIN 16

HardwareSerial BusSerial(1);

struct SlaveCommand {
  int   wheel;
  int   timer;
  float kp, ki, kd;
  int   rpm_in;
};

bool parsePacket(char *line, SlaveCommand &cmd) {
  return sscanf(line, "[%d,%d,%f,%f,%f,%d]",
    &cmd.wheel, &cmd.timer,
    &cmd.kp, &cmd.ki, &cmd.kd,
    &cmd.rpm_in) == 6;
}

void setup() {
  Serial.begin(115200);
  pinMode(PIN_ENABLE, INPUT);
  BusSerial.begin(115200, SERIAL_8N1, RXTX_PIN, RXTX_PIN);
  Serial.printf("Slave %d ready\n", MY_WHEEL);
}

void loop() {
  static char buf[64];
  static int pos = 0;

  while (BusSerial.available()) {
    char c = BusSerial.read();

    if (c == '\n') {
      buf[pos] = '\0';
      pos = 0;

      SlaveCommand cmd;
      if (parsePacket(buf, cmd) && cmd.wheel == MY_WHEEL) {

        int rpm_out = cmd.rpm_in;

        // ===== SEND FEEDBACK =====
        while (digitalRead(PIN_ENABLE) == HIGH);

        char out[32];
        int len = snprintf(out, sizeof(out),
          "[%d,%d,%d]\n",
          cmd.wheel, cmd.timer, rpm_out);

        BusSerial.write((uint8_t*)out, len);
        BusSerial.flush();
      }
    }
    else if (pos < 63) {
      buf[pos++] = c;
    }
  }
}