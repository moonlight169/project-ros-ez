#include <Arduino.h>
#include <HardwareSerial.h>

const int  PIN_ALL    = 4;
const int  TX_PINS[4] = {13, 27, 26, 25};
const long BAUD       = 115200;
const int  RX_TIMEOUT = 5; 

HardwareSerial SlaveSerial(1);

struct SlaveCommand {
  int   wheel, timer;
  float kp, ki, kd;
  int   rpm_in;
};

struct SlaveFeedback {
  int  wheel, timer, rpm_out;
  bool valid;
};

SlaveFeedback sendAndReceive(int idx, SlaveCommand cmd) {
  SlaveFeedback fb = {0, 0, 0, false};

  // ── TX ──
  SlaveSerial.end();
  SlaveSerial.begin(BAUD, SERIAL_8N1, -1, TX_PINS[idx]);

  char buf[64];
  int len = snprintf(buf, sizeof(buf), "[%d,%d,%.1f,%.1f,%.1f,%d]", // ลบ \n ออกจาก buf เพื่อจัด format ตอน print เอง
                     cmd.wheel, cmd.timer, cmd.kp, cmd.ki, cmd.kd, cmd.rpm_in);

  // --- OUTPUT: Send ---
  Serial.printf("S%d Send %s\n", idx + 1, buf); 

  digitalWrite(PIN_ALL, HIGH);
  SlaveSerial.write((uint8_t*)buf, len);
  SlaveSerial.write('\n'); // ส่ง \n ปิดท้าย
  SlaveSerial.flush();
  digitalWrite(PIN_ALL, LOW);

  // ── RX ──
  SlaveSerial.end();
  SlaveSerial.begin(BAUD, SERIAL_8N1, TX_PINS[idx], -1);

  char line[32];
  int  pos = 0;
  unsigned long t0 = micros();

  while (micros() - t0 < (unsigned long)RX_TIMEOUT * 1000UL) {
    while (SlaveSerial.available()) {
      char c = SlaveSerial.read();
      if (c == '\n') {
        line[pos] = '\0';
        
        // --- OUTPUT: Feedback ---
        Serial.printf("S%d Feedback [%s]\n", idx + 1, line);
        
        if (sscanf(line, "[%d,%d,%d]", &fb.wheel, &fb.timer, &fb.rpm_out) == 3) {
          fb.valid = true;
        }
        return fb;
      }
      if (pos < 31) line[pos++] = c;
    }
  }
  
  Serial.printf("S%d Feedback [TIMEOUT]\n", idx + 1);
  return fb;
}

void setup() {
  Serial.begin(115200);
  pinMode(PIN_ALL, OUTPUT);
  digitalWrite(PIN_ALL, LOW);
  delay(500);
  Serial.println("--- System Start ---");
}

void loop() {
  for (int i = 0; i < 4; i++) {
    SlaveCommand cmd = {i + 1, 160, 1.0f, 1.0f, 1.0f, 250};
    sendAndReceive(i, cmd);
    Serial.println("-------------------");
  }
  // หน่วง 5ms เพื่อให้ Serial Buffer ของคอมพิวเตอร์ไม่เต็มจนเกินไป
  delay(5); 
}